# Environment
APP_ENV=production

# Database
# DB_TYPE options: mysql (default) or sqlsrv (SQL Server)
DB_TYPE=mysql
DB_HOST=localhost
DB_USER=root
DB_PASS=
DB_NAME=gate_portal

# SMTP Email (configure in admin panel or set here)
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM_NAME=GATE Portal - WSU
